{
  "name": "matchamp-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "generate:pokemon": "node ../scripts/generatePokemonList.mjs --force",
    "predev": "node ../scripts/generatePokemonList.mjs",
    "dev": "vite",
    "prebuild": "node ../scripts/generatePokemonList.mjs && node scripts/convert-screenshots.mjs",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "@fontsource/roboto": "^5.2.10",
    "@mui/icons-material": "^5.14.20",
    "@mui/material": "^5.14.20",
    "@mui/x-date-pickers": "^6.18.2",
    "@supabase/supabase-js": "^2.48.0",
    "axios": "^1.6.2",
    "date-fns": "^2.30.0",
    "matchamp": "file:..",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "@vitejs/plugin-react": "^4.1.1",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^8.53.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.4",
    "jsdom": "^28.1.0",
    "sharp": "^0.34.5",
    "typescript": "^5.2.2",
    "vite": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
